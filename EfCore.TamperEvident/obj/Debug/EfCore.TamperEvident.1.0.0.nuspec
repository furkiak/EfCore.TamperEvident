        <dependency id="Microsoft.EntityFrameworkCore" version="9.0.16" exclude="Build,Analyzers" />
        <dependency id="Microsoft.EntityFrameworkCore.Relational" version="9.0.16" exclude="Build,Analyzers" />
        <dependency id="System.Text.Json" version="9.0.16" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
